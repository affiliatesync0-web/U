rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGLAS DE SEGURIDAD SYNC CONNECT ---
    // Actualización forzada para asegurar permisos de checkout

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Para el prototipo, cualquier usuario firmado actúa como admin
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGLAS DE COLECCIONES ---

    match /banks/{bankId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliates/{affiliateId} {
      // Permitimos lectura y actualización pública total para el flujo de ventas
      // Esto previene errores de permisos cuando un comprador (sin login)
      // actualiza el saldo del afiliado que lo refirió.
      allow read: if true; 
      allow create: if true; 
      allow update: if true; 
      allow delete: if isAdmin();
    }

    match /buyers/{buyerId} {
      // Compradores pueden ser creados por afiliados o registrarse solos
      allow read: if true;
      allow write: if true;
    }

    match /sales/{saleId} {
      // Ventas pueden ser creadas por cualquier flujo de checkout
      allow read: if true; 
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
