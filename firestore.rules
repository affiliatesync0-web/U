
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGLAS DE SEGURIDAD SYNC CONNECT ---
    // Actualización para permitir notificaciones y flujos de ventas

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'affiliatesync0@gmail.com' || request.auth.uid == 'admin_uid'); 
    }

    match /banks/{bankId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliates/{affiliateId} {
      allow read: if true; 
      allow create: if true; 
      allow update: if true; 
      allow delete: if isAdmin();
    }

    match /buyers/{buyerId} {
      allow read: if true;
      allow write: if true;
    }

    match /sales/{saleId} {
      allow read: if true; 
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if true; // Permitir que el sistema cree notificaciones
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
