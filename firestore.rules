/**
 * NicaAffiliate Connect - Security Rules Architecture
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a strict authorization model centered around Identity and Roles.
 * It prioritizes "Authorization Independence" by ensuring that every document contains
 * the necessary metadata (e.g., affiliateId) to make security decisions locally,
 * minimizing the need for expensive cross-document lookups.
 *
 * DATA STRUCTURE:
 * - /banks: Publicly readable reference data for Nicaragua's banking system.
 * - /products: Global catalog of sellable items, browsable by all authenticated affiliates.
 * - /affiliates: User profiles where the Document ID matches the Firebase Auth UID.
 * - /sales: Transactional records linked to affiliates via an internal `affiliateId` field.
 * - /roles_admin: A protected collection where the presence of a UID grants administrative access.
 *
 * KEY SECURITY DECISIONS:
 * 1. Admin Overrides: An internal `isAdmin()` function grants full CRUD access across
 *    the database based on entries in the `/roles_admin` collection.
 * 2. Ownership-Based Sales Access: Affiliates can only read or create sales records where
 *    the `affiliateId` matches their own UID.
 * 3. Self-Management: Affiliates manage their own profiles at `/affiliates/{uid}`.
 * 4. Immutability: Critical relational fields (like `affiliateId` in a Sale) are
 *    locked after creation to prevent data hijacking.
 * 5. Prototyping Flexibility: While authorization is strictly enforced, specific
 *    data schemas (types, optional fields) are not validated to allow for rapid iteration.
 *
 * DENORMALIZATION FOR AUTHORIZATION:
 * - Every `Sale` document MUST include an `affiliateId` field. This allows the rules
 *   to verify ownership instantly without performing a `get()` on the affiliate's profile.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /** Checks if the request is coming from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user has a document in the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Checks if the provided UID matches the authenticated user. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the existing document's owner field matches the authenticated user. */
    function isDocumentOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the global Banks reference collection.
     * @path /banks/{bankId}
     * @allow get, list: If the user is signed in (for form selection).
     * @deny write: If the user is not an administrator.
     * @principle Public Read with Admin-Only Writes.
     */
    match /banks/{bankId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for the Product catalog.
     * @path /products/{productId}
     * @allow get, list: If the user is signed in (to browse available products).
     * @deny write: If the user is not an administrator.
     * @principle Restricted write access for core business configuration.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for Affiliate profiles. UID-based path ownership.
     * @path /affiliates/{affiliateId}
     * @allow create: If the UID matches the auth state and matches the internal ID.
     * @allow get, update: If the user is the owner or an admin.
     * @allow list, delete: Only for administrators.
     * @principle Self-creation and ownership-based management.
     */
    match /affiliates/{affiliateId} {
      allow get: if isOwner(affiliateId) || isAdmin();
      allow list: if isAdmin();
      // Ensure the internal ID field matches the path on creation
      allow create: if isOwner(affiliateId) && request.resource.data.id == affiliateId;
      // Prevent changing the internal ID during updates
      allow update: if (isOwner(affiliateId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for customer (Buyer) records.
     * @path /buyers/{buyerId}
     * @allow get: If admin. (Affiliates view buyer info via Sale documents).
     * @allow create: If signed in (to record a new buyer during a sale).
     * @deny delete, update: If not an administrator.
     * @principle Administrative control of customer PII.
     */
    match /buyers/{buyerId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Rules for Sales transactions. Access is governed by the affiliateId field.
     * @path /sales/{saleId}
     * @allow get, list: If the user's UID matches the document's affiliateId or user is admin.
     * @allow create: If the incoming affiliateId field matches the user's UID.
     * @allow update: If user is admin (affiliates generally cannot modify sales once submitted).
     * @principle QAP (Queryable Authorization Posture) using denormalized ownership fields.
     */
    match /sales/{saleId} {
      allow get: if isDocumentOwner(resource.data.affiliateId) || isAdmin();
      allow list: if isSignedIn(); // Filtering is enforced by the app; rules will reject non-owned docs.

      // Ensure the sale is linked to the authenticated user on creation
      allow create: if isSignedIn() && request.resource.data.affiliateId == request.auth.uid;

      // Only admins can modify or remove sales for auditing and financial integrity
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Internal administrative roles collection.
     * @path /roles_admin/{userId}
     * @allow get, list, write: Only for existing administrators.
     * @principle Bootstrapped administrative access.
     */
    match /roles_admin/{userId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}