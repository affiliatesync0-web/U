rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocumentOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- COLLECTION RULES ---

    match /banks/{bankId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /affiliates/{affiliateId} {
      allow get: if isOwner(affiliateId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(affiliateId) && request.resource.data.id == affiliateId;
      allow update: if (isOwner(affiliateId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /buyers/{buyerId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow get: if isDocumentOwner(resource.data.affiliateId) || isAdmin();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.affiliateId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /site_config/{configId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /roles_admin/{userId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
