
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGLAS DE SEGURIDAD SYNC CONNECT ---
    // En este prototipo, consideramos admin a quien haya pasado la pantalla de login administrativo (autenticado anónimamente)

    function isSignedIn() {
      return request.auth != null;
    }

    match /banks/{bankId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /affiliates/{affiliateId} {
      allow read: if true; 
      allow create: if true; 
      allow update: if true; 
      allow delete: if isSignedIn();
    }

    match /buyers/{buyerId} {
      allow read: if true;
      allow write: if true;
    }

    match /sales/{saleId} {
      allow read: if true; 
      allow create: if true; 
      allow update, delete: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isSignedIn());
      allow create: if true; 
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isSignedIn());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isSignedIn());
    }

    match /site_config/{configId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
